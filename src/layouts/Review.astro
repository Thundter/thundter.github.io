---
import type { MarkdownLayoutProps } from "astro";
import Main from "./Main.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = MarkdownLayoutProps<{
  title: string;
  website?: string;
  poster?: ImageMetadata;
  subtitle?: string;
  date: Date;
  tags: Array<string>;
  brand: string;
  verdict?: string;
  verdictColour?: string;
}>;

const { title, website, poster, subtitle, date, tags, brand, verdict, verdictColour } =
  Astro.props.frontmatter;

const verdict_colour = verdictColour ? `color: ${verdictColour};` : "";

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/[^_]*.{png,jpg,jpeg,tiff,webp,gif,svg,avif}"
);
const imagePath = poster ? `/src/assets/${poster?.src}` : "";
const image = poster && images[imagePath]();
if (poster && !image) {
  throw new Error(`"${poster}" or "${imagePath}" not found!`);
}
---

<Main title="tnplate | Review" , tags={tags}>
  {
    poster && image && (
      <Image
        src={image}
        alt=""
        width={poster.width ?? 800}
        height={poster.height}
      />
    )
  }

  <h2>{brand}</h2>
  {
    website ? (
      <a href={website}>
        <h1>
          {title}
        </h1>
      </a>
    ) : (
      <h1>
        {title}
      </h1>
    )
  }
  <!-- { recommend === Recommend.No && <>👎</> }
  { recommend === Recommend.LeaningNo && <>👎</> }
  { recommend === Recommend.Depends && <>🤔</> }
  { recommend === Recommend.Mid && <>😑</> }
  { recommend === Recommend.LeaningYes && <>👍</> }
  { recommend === Recommend.Yes && <>👍</> } -->
  
  {subtitle && <h2>{subtitle}</h2>}
  {date && <p class="date">published: {date}</p>}
  {tags && <p class="tags">tags: {tags.join(",")}</p>}
  {verdict && <h2>Verdict: <label style={verdict_colour}>{verdict}</label></h2>}
  <slot />
</Main>
<style>
  h1 + h2 {
    margin-bottom: 0rem;
  }

  .figure {
    margin: 0;
  }

  .figure__image {
    max-width: 100%;
    border-radius: 10px;
  }

  .figure__caption {
    font-size: 0.9rem;
  }

  .date,
  .tags {
    padding: 0;
    margin: 0;
    font-size: 0.7rem;
  }
</style>
